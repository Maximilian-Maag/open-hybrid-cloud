# Server
PORT=8080

# Branding (optional — customize for your organization)
APP_NAME=Open Hybrid Cloud
APP_SUBTITLE=Infrastructure Self-Service

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/openhybridcloud?sslmode=disable

# Session secret (random string, min. 32 characters)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Webshop Admin (initial local account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Microsoft Entra ID (OIDC)
# Optional for local development — local admin account works without Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=http://localhost:8080/auth/callback

# SMTP
# Local: Mailpit via `docker compose up -d mailpit` (Web UI: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@open-hybrid-cloud.local
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=false

# Exchange rate API (optional for local development)
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_RATE_API_KEY=
BASE_CURRENCY=EUR

# AI Translation (optional — enables automatic product translations)
# Supported providers: claude, openai, azure, ollama
AI_PROVIDER=claude
AI_API_KEY=
# AI_ENDPOINT=   # required for azure and ollama; optional for claude/openai
# AI_MODEL=claude-haiku-4-5-20251001

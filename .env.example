# Server
PORT=8080

# Datenbank
DATABASE_URL=postgres://postgres:postgres@localhost:5432/infrawebshop?sslmode=disable

# Session (zufälliger Secret, mind. 32 Zeichen)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Webshop Admin (initialer lokaler Account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Microsoft Entra ID (OIDC)
# Für lokale Entwicklung optional — lokaler Admin-Account funktioniert ohne Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=http://localhost:8080/auth/callback

# SMTP
# Lokal: Mailpit via `docker compose up -d mailpit` (Web-UI: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@infra-webshop.local
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=false

# Wechselkurs-API (optional für lokale Entwicklung)
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_RATE_API_KEY=

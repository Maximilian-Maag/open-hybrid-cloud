# Server
PORT=8080

# Branding (optional — customize for your organization)
APP_NAME=Infra Webshop
APP_SUBTITLE=Infrastructure Self-Service

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/infrawebshop?sslmode=disable

# Session secret (random string, min. 32 characters)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Webshop Admin (initial local account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Microsoft Entra ID (OIDC)
# Optional for local development — local admin account works without Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=http://localhost:8080/auth/callback

# SMTP
# Local: Mailpit via `docker compose up -d mailpit` (Web UI: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@infra-webshop.local
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=false

# Exchange rate API (optional for local development)
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_RATE_API_KEY=

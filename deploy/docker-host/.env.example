# Datenbank
POSTGRES_PASSWORD=change-me-strong-password

# Session (zufälliger String, mind. 32 Zeichen)
SESSION_SECRET=change-this-to-a-random-secret-min-32-chars

# Webshop Admin (initialer lokaler Account, nur beim ersten Start verwendet)
ADMIN_EMAIL=admin@your-domain.example.com
ADMIN_PASSWORD=change-me-strong-password

# Microsoft Entra ID (OIDC)
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_REDIRECT_URL=https://your-domain.example.com/auth/callback

# SMTP
SMTP_HOST=smtp.your-mailserver.example.com
SMTP_PORT=587
SMTP_FROM=noreply@your-domain.example.com
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=true

# Wechselkurs-API
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_RATE_API_KEY=your-api-key

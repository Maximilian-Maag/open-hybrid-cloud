# Docker Hub username (used to pull images)
DOCKERHUB_USERNAME=your-dockerhub-username

# Image tag: dev | staging | latest (production)
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Frontend ───────────────────────────────────────────────────────────────────
# Public URL of the application (used by NextAuth)
NEXTAUTH_URL=https://your-domain.example.com
# Random secret for NextAuth JWT signing (min. 32 characters)
NEXTAUTH_SECRET=change-this-to-a-random-secret-min-32-chars

# ── Backend ────────────────────────────────────────────────────────────────────
# Random secret for backend JWT signing (min. 32 characters)
JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# Initial root admin account (only used on first startup when the DB is empty)
ADMIN_EMAIL=admin@your-domain.example.com
ADMIN_PASSWORD=change-me-strong-password

# Exchange rate API (used to fetch current currency conversion rates)
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest

# ── Microsoft Entra ID / OIDC (optional) ──────────────────────────────────────
# Leave blank to disable SSO; only local accounts will work.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Callback URL registered in Entra ID (e.g. https://your-domain.example.com/api/auth/callback)
ENTRA_REDIRECT_URI=

# ── SMTP (optional) ────────────────────────────────────────────────────────────
# Leave blank to disable outgoing email.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@your-domain.example.com
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true

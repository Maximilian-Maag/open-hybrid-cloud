package admin

import (
	"github.com/open-hybrid-cloud/open-hybrid-cloud/src/internal/i18n"
	"github.com/open-hybrid-cloud/open-hybrid-cloud/src/internal/view"
	"github.com/open-hybrid-cloud/open-hybrid-cloud/src/ui/comp"
)

templ AdminAIConfig(vd view.AdminAIConfigView) {
	@comp.Layout(vd.PageData) {
		<div class="mb-6">
			<a href="/admin" class="inline-flex items-center gap-1 text-xs text-slate-400 hover:text-slate-600 mb-2 transition-colors">
				<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
				</svg>
				{ i18n.T("admin.back", vd.Lang) }
			</a>
			<h1 class="text-2xl font-bold text-slate-900">{ i18n.T("admin.ai_title", vd.Lang) }</h1>
			<p class="text-sm text-slate-400 mt-1">{ i18n.T("admin.ai_subtitle", vd.Lang) }</p>
		</div>
		<div class="max-w-lg">
			@comp.Card() {
				@comp.CardBody() {
					<form method="POST" action="/admin/ai-config" class="space-y-4">
						@comp.Field(i18n.T("admin.ai_provider", vd.Lang), "ai_provider", false) {
							@comp.Select("ai_provider", templ.Attributes{}) {
								if vd.AIConfig.AIProvider == "" {
									<option value="" selected>{ i18n.T("admin.ai_disabled", vd.Lang) }</option>
								} else {
									<option value="">{ i18n.T("admin.ai_disabled", vd.Lang) }</option>
								}
								if vd.AIConfig.AIProvider == "claude" {
									<option value="claude" selected>Claude (Anthropic)</option>
								} else {
									<option value="claude">Claude (Anthropic)</option>
								}
								if vd.AIConfig.AIProvider == "openai" {
									<option value="openai" selected>OpenAI</option>
								} else {
									<option value="openai">OpenAI</option>
								}
								if vd.AIConfig.AIProvider == "azure_openai" {
									<option value="azure_openai" selected>Azure OpenAI</option>
								} else {
									<option value="azure_openai">Azure OpenAI</option>
								}
								if vd.AIConfig.AIProvider == "ollama" {
									<option value="ollama" selected>Ollama (local)</option>
								} else {
									<option value="ollama">Ollama (local)</option>
								}
								if vd.AIConfig.AIProvider == "localai" {
									<option value="localai" selected>LocalAI (local)</option>
								} else {
									<option value="localai">LocalAI (local)</option>
								}
							}
						}
						@comp.Field(i18n.T("admin.ai_endpoint", vd.Lang), "ai_endpoint", false) {
							@comp.Input("ai_endpoint", "url", i18n.T("admin.ai_endpoint_hint", vd.Lang), vd.AIConfig.AIEndpoint, templ.Attributes{})
						}
						@comp.Field(i18n.T("admin.ai_api_key", vd.Lang), "ai_api_key", false) {
							@comp.Input("ai_api_key", "password", i18n.T("admin.ai_api_key_hint", vd.Lang), "", templ.Attributes{"autocomplete": "new-password"})
						}
						@comp.Field(i18n.T("admin.ai_model", vd.Lang), "ai_model", false) {
							@comp.Input("ai_model", "text", "claude-haiku-4-5-20251001", vd.AIConfig.AIModel, templ.Attributes{})
						}
						@comp.Btn(i18n.T("common.save", vd.Lang), comp.VPrimary, comp.SzSM, templ.Attributes{"type": "submit"})
					</form>
				}
			}
		</div>
	}
}
